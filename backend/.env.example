DATABASE_URL="postgresql://postgres:postgres@localhost:5433/acct_dev?schema=public"
# Application secrets — use safe placeholders for local development
JWT_SECRET=change_me_jwt_secret
JWT_REFRESH_SECRET=change_me_jwt_refresh
# Primary Stripe secret key used by the app. Prefer `STRIPE_SECRET_KEY`.
STRIPE_SECRET_KEY=sk_test_change_me
# Legacy alternative name supported for backward compatibility:
# STRIPE_SECRET=sk_test_change_me
STRIPE_WEBHOOK_SECRET=whsec_change_me
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Firebase Admin (server-side) — set only if you use Firebase Admin SDK
# The private key must have escaped newlines (\n). Wrap the value in quotes.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Notes:
# - Do NOT commit real secrets. Copy this file to .env and update values as needed.
# - If a .env file was accidentally committed, remove it from the repo history and run:
#   git rm --cached backend/.env