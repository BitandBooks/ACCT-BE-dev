{
    "name": "acct-platform",
    "private": true,
    "workspaces": [
        "backend",
        "frontend"
    ],
    "scripts": {
        "start:backend": "npm --prefix ./backend run start:dev",
        "start:frontend": "npm --prefix ../ACCT-FE-dev/frontend run dev",
        "start:dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\""
    },
    "devDependencies": {
        "concurrently": "^8.0.0"
    },
    "dependencies": {
        "firebase": "^12.13.0"
    }
}
